{
  "openapi": "3.0.3",
  "info": {
    "title": "Tiwana Connect Mobile API",
    "version": "1.0.0",
    "description": "Mobile API contract for the Expo app. All successful and error responses use the ApiResponse wrapper."
  },
  "servers": [
    {
      "url": "http://localhost:3000/api/mobile",
      "description": "Local development"
    },
    {
      "url": "https://<production-domain>/api/mobile",
      "description": "Production placeholder"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "security": [],
        "summary": "Mobile API health",
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "security": [],
        "summary": "Login with username and password",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          },
          "401": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/auth/change-password": {
      "post": {
        "summary": "Change current user's password",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChangePasswordRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          },
          "401": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/me": {
      "get": {
        "summary": "Current user and mobile-safe member",
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/members/me": {
      "get": {
        "summary": "Alias of /me",
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/members/search": {
      "get": {
        "summary": "Search active visible members",
        "parameters": [
          { "$ref": "#/components/parameters/q" },
          { "$ref": "#/components/parameters/limit" },
          { "$ref": "#/components/parameters/cursor" }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/members/tree": {
      "get": {
        "summary": "Family tree for current or focused member",
        "parameters": [
          { "name": "focusMemberId", "in": "query", "schema": { "type": "string" } },
          { "name": "generations", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 6, "default": 3 } },
          { "name": "viewMode", "in": "query", "schema": { "type": "string", "enum": ["close", "branch", "full", "relationship"], "default": "close" } },
          { "name": "includeHiddenNames", "in": "query", "schema": { "type": "string", "enum": ["true", "false"] } }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          },
          "400": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/members/relationship": {
      "get": {
        "summary": "Find relationship path",
        "parameters": [
          { "name": "startMemberId", "in": "query", "schema": { "type": "string" } },
          { "name": "targetMemberId", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/events": {
      "get": {
        "summary": "List mobile events",
        "parameters": [
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["upcoming", "past", "cancelled", "all"], "default": "upcoming" } },
          { "$ref": "#/components/parameters/limit" },
          { "$ref": "#/components/parameters/cursor" }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      },
      "post": {
        "summary": "Create member event",
        "requestBody": {
          "$ref": "#/components/requestBodies/JsonObject"
        },
        "responses": {
          "201": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/events/{id}": {
      "get": {
        "summary": "Event detail",
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          },
          "404": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/events/mine": {
      "get": {
        "summary": "Current user's created and invited events",
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/events/{id}/rsvp": {
      "post": {
        "summary": "RSVP to event",
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/JsonObject"
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/funds": {
      "get": {
        "summary": "List mobile funds",
        "parameters": [
          { "$ref": "#/components/parameters/q" },
          { "$ref": "#/components/parameters/limit" },
          { "$ref": "#/components/parameters/cursor" }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      },
      "post": {
        "summary": "Create member fund",
        "requestBody": {
          "$ref": "#/components/requestBodies/JsonObject"
        },
        "responses": {
          "201": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/funds/{id}": {
      "get": {
        "summary": "Fund detail",
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/funds/{id}/requests": {
      "post": {
        "summary": "Create contribution request for current member",
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/JsonObject"
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/funds/{id}/contributions": {
      "post": {
        "summary": "Submit member contribution",
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/JsonObject"
        },
        "responses": {
          "201": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/funds/my-requests": {
      "get": {
        "summary": "Current user's contribution requests",
        "parameters": [
          { "$ref": "#/components/parameters/limit" },
          { "$ref": "#/components/parameters/cursor" }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/funds/my-contributions": {
      "get": {
        "summary": "Current user's fund transactions",
        "parameters": [
          { "$ref": "#/components/parameters/limit" },
          { "$ref": "#/components/parameters/cursor" }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/directory": {
      "get": {
        "summary": "List mobile directory",
        "parameters": [
          { "$ref": "#/components/parameters/q" },
          { "$ref": "#/components/parameters/limit" },
          { "$ref": "#/components/parameters/cursor" }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/directory/{memberId}": {
      "get": {
        "summary": "Directory member detail",
        "parameters": [
          { "name": "memberId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/directory/me/settings": {
      "get": {
        "summary": "Current user's directory settings",
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      },
      "patch": {
        "summary": "Update current user's directory settings",
        "requestBody": {
          "$ref": "#/components/requestBodies/JsonObject"
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/directory/{memberId}/help-request": {
      "post": {
        "summary": "Send help request to directory member",
        "parameters": [
          { "name": "memberId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/JsonObject"
        },
        "responses": {
          "201": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/help-requests/sent": {
      "get": {
        "summary": "Sent help requests",
        "parameters": [
          { "$ref": "#/components/parameters/limit" },
          { "$ref": "#/components/parameters/cursor" }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/help-requests/received": {
      "get": {
        "summary": "Received help requests",
        "parameters": [
          { "$ref": "#/components/parameters/limit" },
          { "$ref": "#/components/parameters/cursor" }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/help-requests/{id}/respond": {
      "post": {
        "summary": "Accept or decline a help request",
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/JsonObject"
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/help-requests/{id}/complete": {
      "post": {
        "summary": "Complete a help request",
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/help-requests/{id}/cancel": {
      "post": {
        "summary": "Cancel a help request",
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/elections": {
      "get": {
        "summary": "List elections",
        "parameters": [
          { "$ref": "#/components/parameters/limit" },
          { "$ref": "#/components/parameters/cursor" }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/elections/active": {
      "get": {
        "summary": "Current active election",
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/elections/{id}": {
      "get": {
        "summary": "Election detail",
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/elections/{id}/nomination": {
      "post": {
        "summary": "Submit nomination",
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/JsonObject"
        },
        "responses": {
          "201": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/elections/{id}/nomination/withdraw": {
      "post": {
        "summary": "Withdraw nomination",
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/elections/{id}/vote": {
      "post": {
        "summary": "Cast confidential vote",
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/JsonObject"
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          },
          "409": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/elections/{id}/receipt": {
      "get": {
        "summary": "Get vote receipt",
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/elections/{id}/result": {
      "get": {
        "summary": "Get published election result",
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          },
          "403": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/notifications": {
      "get": {
        "summary": "Notification inbox",
        "parameters": [
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["UNREAD", "READ", "ARCHIVED"] } },
          { "$ref": "#/components/parameters/limit" },
          { "$ref": "#/components/parameters/cursor" }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/notifications/unread-count": {
      "get": {
        "summary": "Unread notification count",
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/notifications/{id}/read": {
      "post": {
        "summary": "Mark notification read",
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/notifications/read-all": {
      "post": {
        "summary": "Mark all notifications read",
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/notifications/{id}/archive": {
      "post": {
        "summary": "Archive notification",
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/devices/register-push-token": {
      "post": {
        "summary": "Register Expo push token",
        "requestBody": {
          "$ref": "#/components/requestBodies/JsonObject"
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          },
          "400": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/devices/unregister-push-token": {
      "post": {
        "summary": "Unregister Expo push token",
        "requestBody": {
          "$ref": "#/components/requestBodies/JsonObject"
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/devices/push-tokens": {
      "get": {
        "summary": "List current user's active push tokens",
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    },
    "/notification-preferences": {
      "get": {
        "summary": "Get notification preferences",
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      },
      "patch": {
        "summary": "Update notification preferences",
        "requestBody": {
          "$ref": "#/components/requestBodies/JsonObject"
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "parameters": {
      "id": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "q": {
        "name": "q",
        "in": "query",
        "schema": {
          "type": "string"
        }
      },
      "limit": {
        "name": "limit",
        "in": "query",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        }
      },
      "cursor": {
        "name": "cursor",
        "in": "query",
        "schema": {
          "type": "string"
        }
      }
    },
    "requestBodies": {
      "JsonObject": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      }
    },
    "responses": {
      "Success": {
        "description": "Standard successful ApiResponse wrapper.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiResponse"
            }
          }
        }
      },
      "Error": {
        "description": "Standard error ApiResponse wrapper.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "required": ["data", "error"],
        "properties": {
          "data": {
            "nullable": true
          },
          "error": {
            "nullable": true,
            "$ref": "#/components/schemas/ApiError"
          }
        }
      },
      "ApiError": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": {
            "type": "string",
            "enum": [
              "VALIDATION_ERROR",
              "UNAUTHORIZED",
              "FORBIDDEN",
              "NOT_FOUND",
              "CONFLICT",
              "ACCOUNT_BLOCKED",
              "ACCOUNT_INACTIVE",
              "TOKEN_EXPIRED",
              "RESULT_NOT_PUBLISHED",
              "TREE_TOO_LARGE",
              "PUSH_TOKEN_INVALID",
              "INTERNAL_ERROR"
            ]
          },
          "message": {
            "type": "string"
          },
          "details": {}
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["username", "password"],
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "ChangePasswordRequest": {
        "type": "object",
        "required": ["currentPassword", "newPassword"],
        "properties": {
          "currentPassword": {
            "type": "string"
          },
          "newPassword": {
            "type": "string",
            "minLength": 8
          }
        }
      }
    }
  }
}
