generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SUPER_ADMIN
  PRESIDENT
  MEMBER
}

enum MemberGender {
  MALE
  FEMALE
}

enum VisibilityStatus {
  VISIBLE
  HIDDEN
}

enum MemberStatus {
  ACTIVE
  BLOCKED
  PENDING
}

enum AuditEntityType {
  AUTH
  MEMBER
  USER_ACCOUNT
  FAMILY_RELATIONSHIP
  BULK_IMPORT
  EVENT
  FUND
  DIRECTORY
  MEMBER_TAG
  HELP_REQUEST
  ELECTION
  SYSTEM
}

enum FamilyRelationshipType {
  FATHER
  MOTHER
  SPOUSE
  CHILD
  SIBLING
  GUARDIAN
  OTHER
}

enum EventType {
  FAMILY_EVENT
  OFFICIAL_MEETING
  WEDDING
  EID_GATHERING
  REUNION
  OTHER
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
  ARCHIVED
}

enum EventVisibility {
  ALL_FAMILY
  INVITED_ONLY
  BRANCH_ONLY
}

enum RSVPStatus {
  PENDING
  GOING
  MAYBE
  NOT_GOING
}

enum EventInviteSource {
  MANUAL
  ALL_FAMILY
  ALL_MALES
  ALL_FEMALES
  BRANCH
  FAMILY_HEAD
}

enum FundType {
  FAMILY_GENERAL
  GENERAL
  ZAKAT
  SADAQAH
  EVENT
  PARTY
  EMERGENCY
  MEMBER_HELP
  OTHER
}

enum FundStatus {
  DRAFT
  ACTIVE
  CLOSED
  CANCELLED
  ARCHIVED
}

enum FundVisibility {
  ALL_FAMILY
  INVITED_ONLY
  ADMIN_ONLY
}

enum FundTransactionType {
  CONTRIBUTION
  ZAKAT_INCOME
  SADAQAH_INCOME
  EXPENSE
  DISBURSEMENT
  REFUND
  ADJUSTMENT
}

enum FundTransactionStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
}

enum ContributionRequestStatus {
  PENDING
  PAID
  PARTIALLY_PAID
  WAIVED
  CANCELLED
}

enum FundPaymentMethod {
  CASH
  BANK_TRANSFER
  EASYPAISA
  JAZZCASH
  OTHER
}

enum DirectoryVisibility {
  VISIBLE
  HIDDEN
  LIMITED
}

enum MemberTagType {
  SKILL
  PROFESSION
  CITY
  FAMILY_BRANCH
  INTEREST
  SERVICE
  OTHER
}

enum HelpRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  COMPLETED
  CANCELLED
}

enum HelpRequestPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ElectionStatus {
  DRAFT
  ANNOUNCED
  NOMINATION_OPEN
  NOMINATION_CLOSED
  NOMINATION_REVIEW
  CANDIDATES_ANNOUNCED
  VOTING_SCHEDULED
  VOTING_OPEN
  VOTING_CLOSED
  TALLYING
  RESULT_ANNOUNCED
  PRESIDENT_AUTH_CEREMONY
  COMPLETED
  CANCELLED
}

enum ElectionPhaseType {
  NOMINATION_OPEN
  NOMINATION_CLOSED
  NOMINATION_APPROVAL_COMPLETION
  CANDIDATES_ANNOUNCED
  VOTING_OPEN
  VOTING_CLOSED
  RESULT_ANNOUNCED
  PRESIDENT_AUTH_CEREMONY
  COMPLETED
}

enum NominationStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

enum CandidateStatus {
  ANNOUNCED
  DISQUALIFIED
  WITHDRAWN
}

enum VoterStatus {
  ELIGIBLE
  VOTED
  BLOCKED
  NOT_ELIGIBLE
}

enum ElectionResultStatus {
  NOT_READY
  TALLYING
  FINALIZED
  PUBLISHED
}

enum ElectionAuditAction {
  ELECTION_CREATED
  ELECTION_UPDATED
  PHASE_EXTENDED
  NOMINATION_SUBMITTED
  NOMINATION_APPROVED
  NOMINATION_REJECTED
  CANDIDATES_ANNOUNCED
  VOTE_CAST
  VOTING_OPENED
  VOTING_CLOSED
  TALLY_STARTED
  RESULT_FINALIZED
  RESULT_PUBLISHED
  CEREMONY_SCHEDULED
  PRESIDENT_ASSIGNED
  ELECTION_CANCELLED
}

enum PushProvider {
  EXPO
  FCM
  APNS
}

enum PushPlatform {
  IOS
  ANDROID
  WEB
  UNKNOWN
}

enum PushDeliveryStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  DEVICE_NOT_REGISTERED
  SKIPPED
}

enum NotificationType {
  ANNOUNCEMENT
  EVENT_INVITE
  EVENT_UPDATED
  EVENT_CANCELLED
  EVENT_RSVP
  FUND_REQUEST
  FUND_CONTRIBUTION
  FUND_TRANSACTION_CONFIRMED
  FUND_TRANSACTION_REJECTED
  HELP_REQUEST
  HELP_REQUEST_RESPONSE
  ELECTION_NOMINATION
  ELECTION_NOMINATION_APPROVED
  ELECTION_NOMINATION_REJECTED
  ELECTION_CANDIDATE_ANNOUNCED
  ELECTION_VOTING_OPEN
  ELECTION_RESULT_ANNOUNCED
  PRESIDENT_CEREMONY
  SYSTEM
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

model UserAccount {
  id                 String    @id @default(cuid())
  memberId           String    @unique
  username           String    @unique
  passwordHash       String
  role               UserRole  @default(MEMBER)
  mustChangePassword Boolean   @default(true)
  lastLoginAt        DateTime?
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([role])
  @@index([isActive])
}

model Member {
  id           String           @id
  fullName     String?
  alias        String?
  initials     String
  gender       MemberGender
  visibility   VisibilityStatus @default(VISIBLE)
  status       MemberStatus     @default(ACTIVE)
  isFamilyHead Boolean          @default(false)
  city         String?
  profession   String?
  phone        String?
  branchLabel  String?
  dateOfBirth  DateTime?
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  deletedAt    DateTime?

  userAccount            UserAccount?
  relationshipsFrom      FamilyRelationship[]      @relation("RelationshipFrom")
  relationshipsTo        FamilyRelationship[]      @relation("RelationshipTo")
  auditLogs              AuditLog[]                @relation("AuditActor")
  eventsCreated          FamilyEvent[]             @relation("EventCreatedBy")
  eventInvites           EventInvite[]
  fundsCreated           FamilyFund[]              @relation("FundCreatedBy")
  fundContributions      FundTransaction[]         @relation("FundContributor")
  fundReceipts           FundTransaction[]         @relation("FundRecipient")
  fundsRecorded          FundTransaction[]         @relation("FundRecordedBy")
  fundsConfirmed         FundTransaction[]         @relation("FundConfirmedBy")
  fundRequests           FundContributionRequest[]
  directorySetting       MemberDirectorySetting?
  tagAssignments         MemberTagAssignment[]
  helpRequestsSent       MemberHelpRequest[]       @relation("HelpRequestFrom")
  helpRequestsReceived   MemberHelpRequest[]       @relation("HelpRequestTo")
  electionsCreated       Election[]                @relation("ElectionCreatedBy")
  electionNominations    ElectionNomination[]
  electionCandidates     ElectionCandidate[]
  electionVoters         ElectionVoter[]
  notifications          Notification[]
  devicePushTokens       DevicePushToken[]
  pushDeliveries         PushDelivery[]
  notificationPreference NotificationPreference?

  @@index([gender])
  @@index([visibility])
  @@index([status])
  @@index([isFamilyHead])
  @@index([city])
  @@index([phone])
  @@index([branchLabel])
  @@index([deletedAt])
}

model FamilyRelationship {
  id           String                 @id @default(cuid())
  fromMemberId String
  toMemberId   String
  type         FamilyRelationshipType
  metadata     Json?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  fromMember Member @relation("RelationshipFrom", fields: [fromMemberId], references: [id], onDelete: Cascade)
  toMember   Member @relation("RelationshipTo", fields: [toMemberId], references: [id], onDelete: Cascade)

  @@unique([fromMemberId, toMemberId, type])
  @@index([fromMemberId])
  @@index([toMemberId])
  @@index([type])
  @@index([fromMemberId, type])
  @@index([toMemberId, type])
}

model AuditLog {
  id            String          @id @default(cuid())
  actorMemberId String?
  action        String
  entityType    AuditEntityType
  entityId      String?
  metadata      Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime        @default(now())

  actor Member? @relation("AuditActor", fields: [actorMemberId], references: [id], onDelete: SetNull)

  @@index([actorMemberId])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BulkImportBatch {
  id          String   @id @default(cuid())
  type        String
  totalRows   Int
  successRows Int
  failedRows  Int
  createdById String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([createdAt])
}

model FamilyEvent {
  id              String          @id @default(cuid())
  title           String
  description     String?
  type            EventType       @default(FAMILY_EVENT)
  status          EventStatus     @default(PUBLISHED)
  visibility      EventVisibility @default(INVITED_ONLY)
  isOfficial      Boolean         @default(false)
  isPinned        Boolean         @default(false)
  startAt         DateTime
  endAt           DateTime?
  timezone        String          @default("Asia/Karachi")
  locationName    String?
  locationAddress String?
  mapUrl          String?
  createdById     String
  updatedById     String?
  cancelledAt     DateTime?
  cancelledById   String?
  cancelReason    String?
  metadata        Json?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  createdBy Member        @relation("EventCreatedBy", fields: [createdById], references: [id])
  invites   EventInvite[]

  @@index([status])
  @@index([type])
  @@index([isOfficial])
  @@index([isPinned])
  @@index([startAt])
  @@index([createdById])
  @@index([deletedAt])
}

model EventInvite {
  id          String            @id @default(cuid())
  eventId     String
  memberId    String
  source      EventInviteSource @default(MANUAL)
  rsvpStatus  RSVPStatus        @default(PENDING)
  rsvpNote    String?
  respondedAt DateTime?
  invitedById String?
  invitedAt   DateTime          @default(now())
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  event  FamilyEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member Member      @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([eventId, memberId])
  @@index([eventId])
  @@index([memberId])
  @@index([rsvpStatus])
  @@index([source])
}

model FamilyFund {
  id             String         @id @default(cuid())
  title          String
  description    String?
  type           FundType       @default(FAMILY_GENERAL)
  status         FundStatus     @default(ACTIVE)
  visibility     FundVisibility @default(ALL_FAMILY)
  targetAmount   Decimal?       @db.Decimal(12, 2)
  currency       String         @default("PKR")
  isOfficial     Boolean        @default(false)
  isPinned       Boolean        @default(false)
  startAt        DateTime?
  endAt          DateTime?
  createdById    String
  updatedById    String?
  relatedEventId String?
  metadata       Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  createdBy    Member                    @relation("FundCreatedBy", fields: [createdById], references: [id])
  transactions FundTransaction[]
  requests     FundContributionRequest[]

  @@index([type])
  @@index([status])
  @@index([visibility])
  @@index([isOfficial])
  @@index([isPinned])
  @@index([createdById])
  @@index([relatedEventId])
  @@index([deletedAt])
}

model FundTransaction {
  id                String                @id @default(cuid())
  fundId            String
  type              FundTransactionType
  status            FundTransactionStatus @default(PENDING)
  amount            Decimal               @db.Decimal(12, 2)
  currency          String                @default("PKR")
  contributorId     String?
  recipientMemberId String?
  paymentMethod     FundPaymentMethod?
  referenceNumber   String?
  note              String?
  recordedById      String?
  confirmedById     String?
  confirmedAt       DateTime?
  rejectedById      String?
  rejectedAt        DateTime?
  rejectReason      String?
  requestId         String?
  metadata          Json?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  deletedAt         DateTime?

  fund            FamilyFund               @relation(fields: [fundId], references: [id], onDelete: Cascade)
  contributor     Member?                  @relation("FundContributor", fields: [contributorId], references: [id])
  recipientMember Member?                  @relation("FundRecipient", fields: [recipientMemberId], references: [id])
  recordedBy      Member?                  @relation("FundRecordedBy", fields: [recordedById], references: [id])
  confirmedBy     Member?                  @relation("FundConfirmedBy", fields: [confirmedById], references: [id])
  request         FundContributionRequest? @relation(fields: [requestId], references: [id])

  @@index([fundId])
  @@index([type])
  @@index([status])
  @@index([contributorId])
  @@index([recipientMemberId])
  @@index([recordedById])
  @@index([requestId])
  @@index([createdAt])
}

model FundContributionRequest {
  id              String                    @id @default(cuid())
  fundId          String
  memberId        String
  requestedAmount Decimal?                  @db.Decimal(12, 2)
  paidAmount      Decimal                   @default(0) @db.Decimal(12, 2)
  currency        String                    @default("PKR")
  status          ContributionRequestStatus @default(PENDING)
  requestedById   String?
  note            String?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  fund         FamilyFund        @relation(fields: [fundId], references: [id], onDelete: Cascade)
  member       Member            @relation(fields: [memberId], references: [id], onDelete: Cascade)
  transactions FundTransaction[]

  @@unique([fundId, memberId])
  @@index([fundId])
  @@index([memberId])
  @@index([status])
}

model MemberDirectorySetting {
  id                String              @id @default(cuid())
  memberId          String              @unique
  visibility        DirectoryVisibility @default(VISIBLE)
  showPhone         Boolean             @default(false)
  showCity          Boolean             @default(true)
  showProfession    Boolean             @default(true)
  allowHelpRequests Boolean             @default(true)
  bio               String?
  availabilityNote  String?
  metadata          Json?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([visibility])
}

model MemberTag {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  type        MemberTagType @default(OTHER)
  description String?
  color       String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  members MemberTagAssignment[]

  @@index([type])
  @@index([isActive])
}

model MemberTagAssignment {
  id           String   @id @default(cuid())
  memberId     String
  tagId        String
  assignedById String?
  createdAt    DateTime @default(now())

  member Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  tag    MemberTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([memberId, tagId])
  @@index([memberId])
  @@index([tagId])
}

model MemberHelpRequest {
  id              String              @id @default(cuid())
  fromMemberId    String
  toMemberId      String
  title           String
  message         String
  category        String?
  priority        HelpRequestPriority @default(NORMAL)
  status          HelpRequestStatus   @default(PENDING)
  responseMessage String?
  respondedAt     DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  metadata        Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deletedAt       DateTime?

  fromMember Member @relation("HelpRequestFrom", fields: [fromMemberId], references: [id], onDelete: Cascade)
  toMember   Member @relation("HelpRequestTo", fields: [toMemberId], references: [id], onDelete: Cascade)

  @@index([fromMemberId])
  @@index([toMemberId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@index([deletedAt])
}

model Election {
  id                    String               @id @default(cuid())
  title                 String
  description           String?
  positionTitle         String               @default("President")
  status                ElectionStatus       @default(DRAFT)
  resultStatus          ElectionResultStatus @default(NOT_READY)
  nominationStartAt     DateTime
  nominationEndAt       DateTime
  approvalDeadlineAt    DateTime?
  candidatesAnnouncedAt DateTime?
  votingStartAt         DateTime
  votingEndAt           DateTime
  resultAnnouncedAt     DateTime?
  ceremonyAt            DateTime?
  eligibilityRules      Json?
  maxVotesPerMember     Int                  @default(1)
  isPublished           Boolean              @default(false)
  isLocked              Boolean              @default(false)
  lockedAt              DateTime?
  winnerCandidateId     String?
  winnerMemberId        String?
  createdById           String
  updatedById           String?
  cancelledAt           DateTime?
  cancelledById         String?
  cancelReason          String?
  metadata              Json?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  deletedAt             DateTime?

  createdBy   Member               @relation("ElectionCreatedBy", fields: [createdById], references: [id])
  phases      ElectionPhase[]
  nominations ElectionNomination[]
  candidates  ElectionCandidate[]
  voters      ElectionVoter[]
  ballots     ElectionBallot[]
  result      ElectionResult?
  audits      ElectionAudit[]

  @@index([status])
  @@index([resultStatus])
  @@index([votingStartAt])
  @@index([votingEndAt])
  @@index([isPublished])
  @@index([isLocked])
  @@index([deletedAt])
}

model ElectionPhase {
  id             String            @id @default(cuid())
  electionId     String
  type           ElectionPhaseType
  title          String
  description    String?
  startsAt       DateTime?
  endsAt         DateTime?
  completedAt    DateTime?
  isActive       Boolean           @default(false)
  isCompleted    Boolean           @default(false)
  extensionCount Int               @default(0)
  metadata       Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  election Election @relation(fields: [electionId], references: [id], onDelete: Cascade)

  @@unique([electionId, type])
  @@index([electionId])
  @@index([type])
}

model ElectionNomination {
  id              String           @id @default(cuid())
  electionId      String
  memberId        String
  status          NominationStatus @default(PENDING)
  statement       String
  manifesto       String?
  experience      String?
  goals           String?
  slogan          String?
  reviewedById    String?
  reviewedAt      DateTime?
  rejectionReason String?
  submittedAt     DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  election  Election           @relation(fields: [electionId], references: [id], onDelete: Cascade)
  member    Member             @relation(fields: [memberId], references: [id], onDelete: Cascade)
  candidate ElectionCandidate?

  @@unique([electionId, memberId])
  @@index([electionId])
  @@index([memberId])
  @@index([status])
}

model ElectionCandidate {
  id                     String          @id @default(cuid())
  electionId             String
  nominationId           String?         @unique
  memberId               String
  status                 CandidateStatus @default(ANNOUNCED)
  displayOrder           Int             @default(0)
  statement              String
  manifesto              String?
  goals                  String?
  slogan                 String?
  announcedAt            DateTime?
  disqualifiedAt         DateTime?
  disqualifiedById       String?
  disqualificationReason String?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  election   Election            @relation(fields: [electionId], references: [id], onDelete: Cascade)
  member     Member              @relation(fields: [memberId], references: [id], onDelete: Cascade)
  nomination ElectionNomination? @relation(fields: [nominationId], references: [id])

  @@unique([electionId, memberId])
  @@index([electionId])
  @@index([memberId])
  @@index([status])
}

model ElectionVoter {
  id                String      @id @default(cuid())
  electionId        String
  memberId          String
  status            VoterStatus @default(ELIGIBLE)
  hasVoted          Boolean     @default(false)
  votedAt           DateTime?
  receiptHash       String?
  receiptCode       String?
  eligibilityReason String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  election Election @relation(fields: [electionId], references: [id], onDelete: Cascade)
  member   Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([electionId, memberId])
  @@index([electionId])
  @@index([memberId])
  @@index([status])
  @@index([hasVoted])
}

model ElectionBallot {
  id                 String   @id @default(cuid())
  electionId         String
  encryptedPayload   String
  iv                 String
  authTag            String
  ballotHash         String   @unique
  previousBallotHash String?
  hashChainIndex     Int
  castAt             DateTime @default(now())

  election Election @relation(fields: [electionId], references: [id], onDelete: Cascade)

  @@index([electionId])
  @@index([hashChainIndex])
  @@index([castAt])
}

model ElectionResult {
  id                  String               @id @default(cuid())
  electionId          String               @unique
  status              ElectionResultStatus @default(NOT_READY)
  totalEligibleVoters Int                  @default(0)
  totalVotesCast      Int                  @default(0)
  invalidBallots      Int                  @default(0)
  winnerCandidateId   String?
  winnerMemberId      String?
  resultsJson         Json?
  resultHash          String?
  finalizedAt         DateTime?
  finalizedBySystem   Boolean              @default(false)
  publishedAt         DateTime?
  publishedById       String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  election Election @relation(fields: [electionId], references: [id], onDelete: Cascade)
}

model ElectionAudit {
  id            String              @id @default(cuid())
  electionId    String
  actorMemberId String?
  action        ElectionAuditAction
  entityId      String?
  metadata      Json?
  createdAt     DateTime            @default(now())

  election Election @relation(fields: [electionId], references: [id], onDelete: Cascade)

  @@index([electionId])
  @@index([actorMemberId])
  @@index([action])
  @@index([createdAt])
}

model Notification {
  id          String               @id @default(cuid())
  memberId    String
  type        NotificationType
  priority    NotificationPriority @default(NORMAL)
  status      NotificationStatus   @default(UNREAD)
  title       String
  body        String?
  actionLabel String?
  actionUrl   String?
  entityType  String?
  entityId    String?
  readAt      DateTime?
  archivedAt  DateTime?
  metadata    Json?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  deletedAt   DateTime?

  member         Member         @relation(fields: [memberId], references: [id], onDelete: Cascade)
  pushDeliveries PushDelivery[]

  @@index([memberId])
  @@index([type])
  @@index([status])
  @@index([priority])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model DevicePushToken {
  id         String       @id @default(cuid())
  memberId   String
  token      String       @unique
  provider   PushProvider @default(EXPO)
  platform   PushPlatform @default(UNKNOWN)
  deviceId   String?
  deviceName String?
  isActive   Boolean      @default(true)
  lastSeenAt DateTime     @default(now())
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  member     Member         @relation(fields: [memberId], references: [id], onDelete: Cascade)
  deliveries PushDelivery[]

  @@index([memberId])
  @@index([provider])
  @@index([platform])
  @@index([isActive])
  @@index([lastSeenAt])
}

model PushDelivery {
  id                String             @id @default(cuid())
  notificationId    String?
  memberId          String
  pushTokenId       String?
  provider          PushProvider       @default(EXPO)
  status            PushDeliveryStatus @default(PENDING)
  title             String
  body              String?
  data              Json?
  providerTicketId  String?
  providerReceiptId String?
  providerError     String?
  sentAt            DateTime?
  deliveredAt       DateTime?
  failedAt          DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  notification Notification?    @relation(fields: [notificationId], references: [id], onDelete: SetNull)
  member       Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  pushToken    DevicePushToken? @relation(fields: [pushTokenId], references: [id], onDelete: SetNull)

  @@index([notificationId])
  @@index([memberId])
  @@index([pushTokenId])
  @@index([status])
  @@index([provider])
  @@index([createdAt])
}

model NotificationPreference {
  id                String   @id @default(cuid())
  memberId          String   @unique
  pushEnabled       Boolean  @default(true)
  announcementsPush Boolean  @default(true)
  eventInvitesPush  Boolean  @default(true)
  fundsPush         Boolean  @default(true)
  helpRequestsPush  Boolean  @default(true)
  electionsPush     Boolean  @default(true)
  systemPush        Boolean  @default(true)
  quietHoursEnabled Boolean  @default(false)
  quietHoursStart   String?
  quietHoursEnd     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
}
